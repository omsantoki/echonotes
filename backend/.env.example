# EchoNotes — environment template. Copy to `.env` and adjust.
# Raw audio is never persisted (Constitution Art. IV); no audio storage config exists by design.

# --- Provider for transcribe / embed / merge ---
#   local  = on-device, no API or keys (default): faster-whisper + sentence-transformers + Ollama
#   openai = hosted OpenAI (needs OPENAI_API_KEY + account credit)
PROVIDER=local

# --- Local stack (used when PROVIDER=local) ---
WHISPER_MODEL=small                      # faster-whisper size: tiny|base|small|medium (bigger = more accurate, slower)
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2   # THE one embedding model (Art. VI)
OLLAMA_BASE_URL=http://localhost:11434   # install Ollama from https://ollama.com, then `ollama pull llama3.1`
OLLAMA_MODEL=llama3.1                    # any chat model you've pulled (e.g. llama3.2 for weaker hardware)
OLLAMA_VISION_MODEL=llava                # vision model for diagram descriptions; `ollama pull llava`

# --- Diagram descriptions (Strong, T030) ---
DESCRIBE_DIAGRAMS=true                    # set false to skip vision descriptions (diagrams still shown)

# --- Optional refine pass (second LLM cleanup) ---
# The merge already does the union + dedupe + clean rewrite, so this is OFF by default.
REFINE_NOTES=false                       # set true to run an extra cleanup pass
REFINE_MODEL=                            # blank = reuse the merge model; or name another pulled model

# --- OpenAI (used only when PROVIDER=openai) ---
OPENAI_API_KEY=sk-...
CHAT_MODEL=gpt-4o                        # merge/composition + diagram vision (multimodal)
TRANSCRIBE_MODEL=whisper-1               # audio -> timestamped segments
EMBEDDING_MODEL=text-embedding-3-small   # OpenAI's embedding model

# --- Storage (local files; the default) ---
CHROMA_DIR=./.chroma                     # vector store persistence dir
DATA_DIR=./data                          # course/lecture registry (JSON) + diagram images — never audio

# --- Managed storage backends (production) ---
# Leave ALL blank for local dev (Chroma + registry.json + on-disk images). Each
# subsystem switches to its managed service the moment its env var is set.
# Vectors → Qdrant if QDRANT_URL set; else remote Chroma if CHROMA_HTTP_URL set; else local.
QDRANT_URL=                              # e.g. https://xxx.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=notechunks
QDRANT_TIMEOUT=60                        # seconds; raise if cross-region upserts time out
CHROMA_HTTP_URL=                         # alternative to Qdrant: remote Chroma, e.g. http://host:8000
CHROMA_API_KEY=
# Registry → managed Postgres if DATABASE_URL set; else local registry.json.
DATABASE_URL=                            # postgresql://user:pass@host/db?sslmode=require  (run `python scripts/init_db.py` from backend/ once)
# Diagram images → object storage (R2/S3) if S3_BUCKET set; else local disk + /assets.
S3_BUCKET=
S3_ENDPOINT_URL=                         # Cloudflare R2 endpoint; blank for AWS S3
S3_REGION=auto                           # "auto" for R2; a real region (e.g. us-east-1) for S3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=                      # public URL prefix for served images, e.g. https://assets.example.com

# --- CORS (production) ---
# The React SPA's origin(s), comma-separated (dev uses the Vite proxy, so blank is fine locally).
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Server-rendered console (app/web.py) ---
# Single-tenant admin view with NO login (acts as the bootstrap admin). Handy locally;
# MUST be false on any public backend or anyone could create courses / upload lectures
# (spending the OpenAI budget) and read the admin's data. Production sets this false.
ENABLE_WEB_CONSOLE=true

# --- Pipeline tuning ---
ALIGN_TOP_K=3                            # attach each spoken segment to its top-3 near-tie slide sections (D-1)
RETRIEVE_TOP_N=5                         # cap cross-lecture context (Art. VI rationale)

# --- Cross-lecture linking (Stretch, T040/T041) ---
LINK_LECTURES=true                       # link each topic to the most similar earlier lecture in the course
LINK_MIN_SIMILARITY=0.5                  # only link when cosine similarity clears this (0-1)

# --- Auth & multi-tenancy (feature 002, Constitution Art. X) ---
# Leave ALL of these blank for local dev: blank JWT_SECRET → a dev-only key, blank SMTP →
# OTPs/reset links print to the server log, blank GOOGLE_OAUTH_CLIENT_ID → Google button hidden.
# NEVER deploy with a blank JWT_SECRET — set a strong random value in production.
# IMPORTANT: keep blank-value lines comment-free — an inline "# comment" after an empty value is
# read AS the value by the loader (see project memory). Comments for blanks go on the line above.
JWT_SECRET=
JWT_EXPIRY=86400
OTP_TTL=600
OTP_MAX_ATTEMPTS=5
RESET_TOKEN_TTL=3600
FRONTEND_URL=http://localhost:5173
BOOTSTRAP_ADMIN_EMAIL=admin@echonotes.local

# SMTP for OTP + reset emails. Blank SMTP_HOST = print the OTP / link to the server log.
# (Gmail: SMTP_HOST=smtp.gmail.com, SMTP_USER=you@gmail.com, SMTP_PASSWORD=an App Password.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Google sign-in (Strong). Blank = "Continue with Google" hidden; /api/auth/google returns 503.
# Must be a Web OAuth client id; add the SPA origin to its authorized JavaScript origins.
GOOGLE_OAUTH_CLIENT_ID=

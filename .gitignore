.venv/
__pycache__/
*.pyc
.pytest_cache/
.DS_Store

# Backend config + local state (the app runs from backend/).
backend/.env
backend/.chroma/
backend/data/

# Frontend env files — keep only the committed template (.env.example).
frontend/.env
frontend/.env.*
!frontend/.env.example

# Test/coverage artifacts (regenerated by CI; never committed).
*.coverage
backend/.coverage
frontend/coverage/

# Never commit raw audio (Art. IV). Demo slides/audio live in backend/samples/
# deliberately; keep large media out of git unless it's the curated demo asset.
backend/samples/*.wav
backend/samples/*.mp3
backend/samples/*.m4a
DEPLOY.md 
DOCUMENTATION.md
EchoNotes_api_key.txt
echonotes-s3_accessKeys.csv
.txt
data

# Graphify code-structure map: commit the queryable graph + report;
# ignore the heavy/regenerable artifacts (HTML viz, caches, cost/manifest, sidecars).
graphify-out/*
!graphify-out/graph.json
!graphify-out/GRAPH_REPORT.md

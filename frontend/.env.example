# Origin of the EchoNotes FastAPI backend.
# Leave blank in development (the Vite dev proxy forwards /api and /assets).
# In production set this to the deployed backend origin (no trailing slash):
#   VITE_API_BASE=https://api.echonotes.example.com
VITE_API_BASE=

# Google sign-in (feature 002). Blank = the "Continue with Google" button is hidden.
# Use the SAME Web OAuth client id as the backend's GOOGLE_OAUTH_CLIENT_ID, and add this
# SPA's origin to that client's authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=
